{
  "name": "userscripts",
  "version": "0.0.2",
  "description": "custom userscripts for better experience",
  "scripts": {
    "clean": "rm -rf public",
    "build": "npm run clean && node scripts/style.build.js && node scripts/imgur.build.js",
