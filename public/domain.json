{
  "rules": [
    {
      "file": "baidu.css",
      "match": ["*://baidu.com/*", "*://www.baidu.com/*"]
    },
    {
      "file": "zhihu.css",
      "match": ["*://www.zhihu.com/*"]
    },
    {
      "file": "bilibili.css",
      "match": ["*://www.bilibili.com/*"]
    },
    {
      "file": "bing.css",
      "match": ["*://bing.com/*", "*://*.bing.com/*"]
    },
    {
      "file": "google.css",
      "match": [
        "*://google.com/*",
        "*://www.google.com/*",
        "*://www.google.co.uk/*",
        "*://www.google.com.hk/*"
      ]
    },
    {
      "file": "deepseek.css",
      "match": ["*://chat.deepseek.com/*"]
    }
  ]
}
